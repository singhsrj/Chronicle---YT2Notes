# Chronicle - YT to Notes
# Docker Environment Variables
# Copy to .env and customize as needed

# Ollama Configuration
# -------------------
# For Windows/Mac Docker Desktop, use: http://host.docker.internal:11434
# For Linux, use: http://172.17.0.1:11434 (or your host's IP)
OLLAMA_HOST=http://host.docker.internal:11434

# Model to use for notes generation
OLLAMA_MODEL=llama2:7b
